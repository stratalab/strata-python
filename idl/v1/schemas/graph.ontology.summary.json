{
  "$defs": {
    "GraphLinkTypeSummaryData": {
      "description": "One link type with its visible edge count (wire form).",
      "properties": {
        "cardinality": {
          "type": [
            "string",
            "null"
          ]
        },
        "edge_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "additionalProperties": {
            "$ref": "#/$defs/GraphPropertyDef"
          },
          "type": "object"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "source",
        "target",
        "edge_count"
      ],
      "type": "object"
    },
    "GraphObjectTypeSummaryData": {
      "description": "One object type with its visible node count (wire form).",
      "properties": {
        "name": {
          "type": "string"
        },
        "node_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "properties": {
          "additionalProperties": {
            "$ref": "#/$defs/GraphPropertyDef"
          },
          "type": "object"
        }
      },
      "required": [
        "name",
        "node_count"
      ],
      "type": "object"
    },
    "GraphOntologySummaryData": {
      "description": "The ontology with per-type usage counts (wire form).",
      "properties": {
        "graph": {
          "type": "string"
        },
        "link_types": {
          "items": {
            "$ref": "#/$defs/GraphLinkTypeSummaryData"
          },
          "type": "array"
        },
        "object_types": {
          "items": {
            "$ref": "#/$defs/GraphObjectTypeSummaryData"
          },
          "type": "array"
        },
        "status": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "status",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "GraphPropertyDef": {
      "description": "One declared property on a graph object or link type (wire form).\n`value_type` is a recorded hint, not an enforced constraint.",
      "properties": {
        "required": {
          "default": false,
          "type": "boolean"
        },
        "value_type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.ontology.summary.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.ontology.summary",
  "request": {
    "additionalProperties": false,
    "description": "Reads the ontology with per-type node and edge usage counts.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_ontology_summary",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph ontology summary result with per-type usage counts.",
    "properties": {
      "data": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphOntologySummaryData"
          },
          {
            "type": "null"
          }
        ]
      },
      "type": {
        "const": "graph_ontology_summary_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
