{
  "$defs": {
    "GraphLinkTypeDefData": {
      "description": "A declared link type (wire form). `cardinality` is a recorded hint.",
      "properties": {
        "cardinality": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "additionalProperties": {
            "$ref": "#/$defs/GraphPropertyDef"
          },
          "type": "object"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "source",
        "target"
      ],
      "type": "object"
    },
    "GraphObjectTypeDefData": {
      "description": "A declared object type (wire form).",
      "properties": {
        "name": {
          "type": "string"
        },
        "properties": {
          "additionalProperties": {
            "$ref": "#/$defs/GraphPropertyDef"
          },
          "type": "object"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "GraphOntologyData": {
      "description": "A graph's ontology: status plus every declared type (wire form).",
      "properties": {
        "graph": {
          "type": "string"
        },
        "link_types": {
          "items": {
            "$ref": "#/$defs/GraphLinkTypeDefData"
          },
          "type": "array"
        },
        "object_types": {
          "items": {
            "$ref": "#/$defs/GraphObjectTypeDefData"
          },
          "type": "array"
        },
        "status": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "status",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "GraphPropertyDef": {
      "description": "One declared property on a graph object or link type (wire form).\n`value_type` is a recorded hint, not an enforced constraint.",
      "properties": {
        "required": {
          "default": false,
          "type": "boolean"
        },
        "value_type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.ontology.get.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.ontology.get",
  "request": {
    "additionalProperties": false,
    "description": "Reads the graph's ontology (status plus every declared type).",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_get_ontology",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph ontology read result (`None` before any type is defined).",
    "properties": {
      "data": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphOntologyData"
          },
          {
            "type": "null"
          }
        ]
      },
      "type": {
        "const": "graph_ontology_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
