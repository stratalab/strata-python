{
  "$defs": {
    "EmbedResponse": {
      "description": "Batch embedding response.",
      "properties": {
        "dimension": {
          "description": "Embedding dimension when known.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "items": {
          "description": "Ordered embedding item outcomes.",
          "items": {
            "$ref": "#/$defs/EmbedRuntimeOutcome"
          },
          "type": "array"
        }
      },
      "required": [
        "items",
        "dimension"
      ],
      "type": "object"
    },
    "EmbedRuntimeOutcome": {
      "description": "Embedding item outcome.",
      "oneOf": [
        {
          "description": "Successful embedding item.",
          "properties": {
            "status": {
              "const": "ok",
              "type": "string"
            },
            "vector": {
              "description": "Embedding vector.",
              "items": {
                "format": "float",
                "type": "number"
              },
              "type": "array"
            }
          },
          "required": [
            "status",
            "vector"
          ],
          "type": "object"
        },
        {
          "description": "Failed embedding item.",
          "properties": {
            "code": {
              "description": "Stable error code.",
              "type": "string"
            },
            "message": {
              "description": "Redacted public error message.",
              "type": "string"
            },
            "status": {
              "const": "error",
              "type": "string"
            }
          },
          "required": [
            "status",
            "code",
            "message"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/inference.embed_batch.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "inference.embed_batch",
  "request": {
    "additionalProperties": false,
    "description": "Embeds multiple texts with an inference model.",
    "properties": {
      "model": {
        "description": "Model spec.",
        "type": "string"
      },
      "texts": {
        "description": "Ordered texts to embed.",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "type": {
        "const": "inference_embed_batch",
        "type": "string"
      }
    },
    "required": [
      "type",
      "model",
      "texts"
    ],
    "type": "object"
  },
  "response": {
    "description": "Inference batch embedding output.",
    "properties": {
      "data": {
        "$ref": "#/$defs/EmbedResponse"
      },
      "type": {
        "const": "inference_embeddings",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
