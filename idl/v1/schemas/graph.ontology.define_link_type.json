{
  "$defs": {
    "CommitReceipt": {
      "description": "Commit facts returned by mutating operations.",
      "properties": {
        "delete_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "durable": {
          "type": "boolean"
        },
        "put_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "durable",
        "put_count",
        "delete_count"
      ],
      "type": "object"
    },
    "GraphPropertyDef": {
      "description": "One declared property on a graph object or link type (wire form).\n`value_type` is a recorded hint, not an enforced constraint.",
      "properties": {
        "required": {
          "default": false,
          "type": "boolean"
        },
        "value_type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "MutationEffect": {
      "description": "Normalized mutation effect facts.",
      "properties": {
        "affected_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/MutationEffectKind"
        },
        "matched": {
          "type": "boolean"
        }
      },
      "required": [
        "applied",
        "kind",
        "matched",
        "affected_count"
      ],
      "type": "object"
    },
    "MutationEffectKind": {
      "description": "High-level mutation effect for idempotent and conditional operations.",
      "oneOf": [
        {
          "const": "created",
          "description": "A new logical entity was created.",
          "type": "string"
        },
        {
          "const": "updated",
          "description": "An existing logical entity was updated.",
          "type": "string"
        },
        {
          "const": "deleted",
          "description": "An existing logical entity was deleted.",
          "type": "string"
        },
        {
          "const": "unchanged",
          "description": "The operation matched but left state unchanged.",
          "type": "string"
        },
        {
          "const": "not_found",
          "description": "The operation did not match a visible entity.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.ontology.define_link_type.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.ontology.define_link_type",
  "request": {
    "additionalProperties": false,
    "description": "Defines (or, while the ontology is draft, redefines) a link type.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "cardinality": {
        "description": "Optional cardinality: one of `one-to-one`, `one-to-many`,\n`many-to-one`, or `many-to-many`. Unknown values are rejected.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "name": {
        "description": "Link type name.",
        "type": "string"
      },
      "properties": {
        "additionalProperties": {
          "$ref": "#/$defs/GraphPropertyDef"
        },
        "description": "Declared properties by name.",
        "type": "object"
      },
      "source": {
        "description": "Declared source object type.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "target": {
        "description": "Declared target object type.",
        "type": "string"
      },
      "type": {
        "const": "graph_define_link_type",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph",
      "name",
      "source",
      "target"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph ontology type definition acknowledgement.",
    "properties": {
      "data": {
        "properties": {
          "commit": {
            "$ref": "#/$defs/CommitReceipt",
            "description": "Commit receipt."
          },
          "effect": {
            "$ref": "#/$defs/MutationEffect",
            "description": "Mutation effect facts."
          },
          "graph": {
            "description": "Graph name.",
            "type": "string"
          },
          "kind": {
            "description": "Type kind: `object` or `link`.",
            "type": "string"
          },
          "type_name": {
            "description": "Defined type name.",
            "type": "string"
          }
        },
        "required": [
          "graph",
          "kind",
          "type_name",
          "effect",
          "commit"
        ],
        "type": "object"
      },
      "type": {
        "const": "graph_ontology_write_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
