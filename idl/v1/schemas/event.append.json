{
  "$defs": {
    "CommitReceipt": {
      "description": "Commit facts returned by mutating operations.",
      "properties": {
        "delete_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "durable": {
          "type": "boolean"
        },
        "put_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "durable",
        "put_count",
        "delete_count"
      ],
      "type": "object"
    },
    "MutationEffect": {
      "description": "Normalized mutation effect facts.",
      "properties": {
        "affected_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/MutationEffectKind"
        },
        "matched": {
          "type": "boolean"
        }
      },
      "required": [
        "applied",
        "kind",
        "matched",
        "affected_count"
      ],
      "type": "object"
    },
    "MutationEffectKind": {
      "description": "High-level mutation effect for idempotent and conditional operations.",
      "oneOf": [
        {
          "const": "created",
          "description": "A new logical entity was created.",
          "type": "string"
        },
        {
          "const": "updated",
          "description": "An existing logical entity was updated.",
          "type": "string"
        },
        {
          "const": "deleted",
          "description": "An existing logical entity was deleted.",
          "type": "string"
        },
        {
          "const": "unchanged",
          "description": "The operation matched but left state unchanged.",
          "type": "string"
        },
        {
          "const": "not_found",
          "description": "The operation did not match a visible entity.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/event.append.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "event.append",
  "request": {
    "additionalProperties": false,
    "description": "Appends one event.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "event_type": {
        "description": "Event type.",
        "type": "string"
      },
      "payload": {
        "description": "Event payload."
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "event_append",
        "type": "string"
      }
    },
    "required": [
      "type",
      "event_type",
      "payload"
    ],
    "type": "object"
  },
  "response": {
    "description": "Event append acknowledgement.",
    "properties": {
      "data": {
        "properties": {
          "commit": {
            "$ref": "#/$defs/CommitReceipt",
            "description": "Commit receipt."
          },
          "effect": {
            "$ref": "#/$defs/MutationEffect",
            "description": "Mutation effect facts."
          },
          "event_type": {
            "description": "Appended event type.",
            "type": "string"
          },
          "sequence": {
            "description": "Assigned sequence.",
            "format": "uint64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "sequence",
          "event_type",
          "effect",
          "commit"
        ],
        "type": "object"
      },
      "type": {
        "const": "event_append_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
