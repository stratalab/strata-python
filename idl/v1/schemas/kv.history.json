{
  "$defs": {
    "Bytes": {
      "contentEncoding": "base64",
      "description": "Binary payload encoded as a standard base64 string.",
      "type": "string"
    },
    "HistoryItem": {
      "description": "Version-history item.",
      "properties": {
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "tombstone": {
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/Bytes"
            },
            {
              "type": "null"
            }
          ]
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "tombstone",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "HistoryResult": {
      "description": "Version-history result for one key.",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/HistoryItem"
          },
          "type": "array"
        }
      },
      "required": [
        "items"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/kv.history.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "kv.history",
  "request": {
    "additionalProperties": false,
    "description": "Reads full version history for one key.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "key": {
        "$ref": "#/$defs/Bytes",
        "description": "Key to read."
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "kv_history",
        "type": "string"
      }
    },
    "required": [
      "type",
      "key"
    ],
    "type": "object"
  },
  "response": {
    "description": "Full version history for one key.",
    "properties": {
      "data": {
        "anyOf": [
          {
            "$ref": "#/$defs/HistoryResult"
          },
          {
            "type": "null"
          }
        ]
      },
      "type": {
        "const": "version_history",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
