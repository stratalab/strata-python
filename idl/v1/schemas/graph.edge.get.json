{
  "$defs": {
    "GraphEdgeDataOutput": {
      "description": "Serializable graph edge output.",
      "properties": {
        "dst": {
          "type": "string"
        },
        "edge_type": {
          "type": "string"
        },
        "graph": {
          "type": "string"
        },
        "properties": true,
        "src": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "weight": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "graph",
        "src",
        "edge_type",
        "dst",
        "weight",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "Maybe5": {
      "description": "Point-read envelope shared by every capability's single-record `get`.\n\n`found` is the authoritative presence flag; `value` carries the record only\nwhen it exists. A missing record serializes as `{found: false, value: null}`\nand a present one as `{found: true, value: <record>}`, so absence never\naliases a bare `null` payload and every primitive answers a point read the\nsame shape.\n\nThe payload is `Option<T>` because these primitives never store a JSON\n`null` as a record — struct payloads round-trip cleanly through\n`Option<T>`. JSON is the one exception: a stored JSON `null` is a real value\nthat `Option<serde_json::Value>` would collapse to absence on deserialize,\nso JSON reads use the dedicated [`MaybeJsonValue`](super::MaybeJsonValue)\nenvelope, which carries a non-optional `value` to keep found-null distinct\nfrom absent. Both envelopes serialize the same `{found, value}` wire shape.",
      "properties": {
        "found": {
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/GraphEdgeDataOutput"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "found"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.edge.get.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.edge.get",
  "request": {
    "additionalProperties": false,
    "description": "Reads a graph edge.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "dst": {
        "description": "Destination node id.",
        "type": "string"
      },
      "edge_type": {
        "description": "Edge type.",
        "type": "string"
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "src": {
        "description": "Source node id.",
        "type": "string"
      },
      "type": {
        "const": "graph_get_edge",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph",
      "src",
      "edge_type",
      "dst"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph edge point-read result: present edge, or absence.",
    "properties": {
      "data": {
        "$ref": "#/$defs/Maybe5"
      },
      "type": {
        "const": "graph_edge_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
