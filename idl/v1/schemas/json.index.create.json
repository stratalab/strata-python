{
  "$defs": {
    "JsonIndexDefinition": {
      "description": "JSON secondary index definition exposed through the command boundary.",
      "properties": {
        "created_timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "created_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "field_path": {
          "type": "string"
        },
        "index_type": {
          "$ref": "#/$defs/JsonIndexType"
        },
        "name": {
          "type": "string"
        },
        "space": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "space",
        "field_path",
        "index_type",
        "created_version",
        "created_timestamp"
      ],
      "type": "object"
    },
    "JsonIndexType": {
      "description": "JSON secondary index kind exposed through the command boundary.",
      "oneOf": [
        {
          "const": "numeric",
          "description": "Numeric field index.",
          "type": "string"
        },
        {
          "const": "tag",
          "description": "Exact tag/string field index.",
          "type": "string"
        },
        {
          "const": "text",
          "description": "Lowercase text field index.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/json.index.create.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "json.index.create",
  "request": {
    "additionalProperties": false,
    "description": "Creates a JSON secondary index.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "field_path": {
        "description": "Indexed field path.",
        "type": "string"
      },
      "index_type": {
        "$ref": "#/$defs/JsonIndexType",
        "description": "Index kind."
      },
      "name": {
        "description": "Index name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "json_create_index",
        "type": "string"
      }
    },
    "required": [
      "type",
      "name",
      "field_path",
      "index_type"
    ],
    "type": "object"
  },
  "response": {
    "description": "JSON secondary index definition.",
    "properties": {
      "data": {
        "$ref": "#/$defs/JsonIndexDefinition"
      },
      "type": {
        "const": "json_index_definition",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
