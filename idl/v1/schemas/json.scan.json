{
  "$defs": {
    "JsonSampleItem": {
      "description": "Sampled JSON document.",
      "properties": {
        "document_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "key": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "value": true,
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "key",
        "value",
        "version",
        "timestamp",
        "document_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/json.scan.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "json.scan",
  "request": {
    "additionalProperties": false,
    "description": "Scans JSON documents.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "description": "Optional row limit.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "start": {
        "description": "Optional inclusive start document key.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "json_scan",
        "type": "string"
      }
    },
    "required": [
      "type"
    ],
    "type": "object"
  },
  "response": {
    "description": "JSON document scan page.",
    "properties": {
      "data": {
        "description": "Shared pagination continuation facts.",
        "properties": {
          "cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "has_more": {
            "type": "boolean"
          },
          "items": {
            "description": "Documents in this page.",
            "items": {
              "$ref": "#/$defs/JsonSampleItem"
            },
            "type": "array"
          }
        },
        "required": [
          "items",
          "has_more"
        ],
        "type": "object"
      },
      "type": {
        "const": "json_scan_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
