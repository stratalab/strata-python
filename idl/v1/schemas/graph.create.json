{
  "$defs": {
    "CommitReceipt": {
      "description": "Commit facts returned by mutating operations.",
      "properties": {
        "delete_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "durable": {
          "type": "boolean"
        },
        "put_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "durable",
        "put_count",
        "delete_count"
      ],
      "type": "object"
    },
    "GraphInfoData": {
      "description": "Serializable graph metadata.",
      "properties": {
        "created_timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "created_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "edge_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "graph": {
          "type": "string"
        },
        "node_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "updated_timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "updated_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "node_count",
        "edge_count",
        "created_version",
        "created_timestamp",
        "updated_version",
        "updated_timestamp"
      ],
      "type": "object"
    },
    "MutationEffect": {
      "description": "Normalized mutation effect facts.",
      "properties": {
        "affected_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/MutationEffectKind"
        },
        "matched": {
          "type": "boolean"
        }
      },
      "required": [
        "applied",
        "kind",
        "matched",
        "affected_count"
      ],
      "type": "object"
    },
    "MutationEffectKind": {
      "description": "High-level mutation effect for idempotent and conditional operations.",
      "oneOf": [
        {
          "const": "created",
          "description": "A new logical entity was created.",
          "type": "string"
        },
        {
          "const": "updated",
          "description": "An existing logical entity was updated.",
          "type": "string"
        },
        {
          "const": "deleted",
          "description": "An existing logical entity was deleted.",
          "type": "string"
        },
        {
          "const": "unchanged",
          "description": "The operation matched but left state unchanged.",
          "type": "string"
        },
        {
          "const": "not_found",
          "description": "The operation did not match a visible entity.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.create.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.create",
  "request": {
    "additionalProperties": false,
    "description": "Creates a graph.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_create",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph create acknowledgement carrying the new graph metadata and commit\nreceipt.",
    "properties": {
      "data": {
        "properties": {
          "commit": {
            "$ref": "#/$defs/CommitReceipt",
            "description": "Commit receipt."
          },
          "effect": {
            "$ref": "#/$defs/MutationEffect",
            "description": "Mutation effect facts."
          },
          "info": {
            "$ref": "#/$defs/GraphInfoData",
            "description": "Created graph metadata."
          }
        },
        "required": [
          "info",
          "effect",
          "commit"
        ],
        "type": "object"
      },
      "type": {
        "const": "graph_create_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
