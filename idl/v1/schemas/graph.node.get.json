{
  "$defs": {
    "GraphBindingPrimitive": {
      "description": "Product primitive kind used by graph entity bindings.",
      "oneOf": [
        {
          "const": "kv",
          "description": "KV primitive.",
          "type": "string"
        },
        {
          "const": "json",
          "description": "JSON primitive.",
          "type": "string"
        },
        {
          "const": "vector",
          "description": "Vector primitive.",
          "type": "string"
        },
        {
          "const": "event",
          "description": "Event primitive.",
          "type": "string"
        },
        {
          "const": "graph",
          "description": "Graph primitive.",
          "type": "string"
        }
      ]
    },
    "GraphBindingTarget": {
      "description": "Typed product identity attached to a graph node.",
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "type": "string"
        },
        "primitive": {
          "$ref": "#/$defs/GraphBindingPrimitive"
        },
        "space": {
          "type": "string"
        }
      },
      "required": [
        "primitive",
        "space",
        "key"
      ],
      "type": "object"
    },
    "GraphEntityBinding": {
      "description": "Node-to-entity binding.",
      "properties": {
        "target": {
          "$ref": "#/$defs/GraphBindingTarget"
        }
      },
      "required": [
        "target"
      ],
      "type": "object"
    },
    "GraphNodeDataOutput": {
      "description": "Serializable graph node output.",
      "properties": {
        "binding": {
          "anyOf": [
            {
              "$ref": "#/$defs/GraphEntityBinding"
            },
            {
              "type": "null"
            }
          ]
        },
        "graph": {
          "type": "string"
        },
        "node_id": {
          "type": "string"
        },
        "object_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "properties": true,
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "node_id",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "Maybe4": {
      "description": "Point-read envelope shared by every capability's single-record `get`.\n\n`found` is the authoritative presence flag; `value` carries the record only\nwhen it exists. A missing record serializes as `{found: false, value: null}`\nand a present one as `{found: true, value: <record>}`, so absence never\naliases a bare `null` payload and every primitive answers a point read the\nsame shape.\n\nThe payload is `Option<T>` because these primitives never store a JSON\n`null` as a record — struct payloads round-trip cleanly through\n`Option<T>`. JSON is the one exception: a stored JSON `null` is a real value\nthat `Option<serde_json::Value>` would collapse to absence on deserialize,\nso JSON reads use the dedicated [`MaybeJsonValue`](super::MaybeJsonValue)\nenvelope, which carries a non-optional `value` to keep found-null distinct\nfrom absent. Both envelopes serialize the same `{found, value}` wire shape.",
      "properties": {
        "found": {
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/GraphNodeDataOutput"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "found"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.node.get.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.node.get",
  "request": {
    "additionalProperties": false,
    "description": "Reads a graph node.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "node_id": {
        "description": "Node id.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_get_node",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph",
      "node_id"
    ],
    "type": "object"
  },
  "response": {
    "description": "Graph node point-read result: present node, or absence.",
    "properties": {
      "data": {
        "$ref": "#/$defs/Maybe4"
      },
      "type": {
        "const": "graph_node_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
