{
  "$defs": {
    "ChatChoice": {
      "description": "One generation choice.\n\nCarries optional f32 log-probabilities, so this type is [`PartialEq`] but\nnot [`Eq`].",
      "properties": {
        "finish_reason": {
          "$ref": "#/$defs/FinishReason",
          "description": "Why this choice stopped."
        },
        "index": {
          "description": "Choice index.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "logprobs": {
          "anyOf": [
            {
              "$ref": "#/$defs/LogProbs"
            },
            {
              "type": "null"
            }
          ],
          "description": "Per-token log-probabilities, when requested via `logprobs`."
        },
        "message": {
          "$ref": "#/$defs/ChatMessage",
          "description": "The assistant message."
        }
      },
      "required": [
        "index",
        "message",
        "finish_reason"
      ],
      "type": "object"
    },
    "ChatMessage": {
      "description": "One chat message. (Content is text in this phase; typed multimodal parts\narrive in a later phase.)",
      "properties": {
        "content": {
          "default": "",
          "description": "Message text. Empty (or omitted) for an assistant turn that only calls\ntools.",
          "type": "string"
        },
        "name": {
          "description": "Optional author name (OpenAI `name`).",
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "$ref": "#/$defs/Role",
          "description": "Message author."
        },
        "tool_call_id": {
          "description": "For a `tool` message: the id of the [`ToolCall`] this message answers.",
          "type": [
            "string",
            "null"
          ]
        },
        "tool_calls": {
          "description": "Tool calls emitted by the assistant (function calling). Present on an\nassistant message that invokes one or more tools.",
          "items": {
            "$ref": "#/$defs/ToolCall"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "required": [
        "role"
      ],
      "type": "object"
    },
    "ChatRequest": {
      "description": "A generation request: the OpenAI Chat Completions body plus Strata /\nllama.cpp extension fields.\n\nExactly one of `messages` (chat) or `prompt` (raw completion) must be set.\nUnknown fields are ignored (OpenAI-compatible, forward-compatible with\nprovider `extra_body`), a deliberate exception to Strata's strict-wire\ndefault for this knob-rich body.",
      "properties": {
        "frequency_penalty": {
          "description": "Frequency penalty.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "grammar": {
          "description": "GBNF grammar for constrained generation (local).",
          "type": [
            "string",
            "null"
          ]
        },
        "logit_bias": {
          "additionalProperties": false,
          "description": "Per-token logit bias (token id → bias).",
          "patternProperties": {
            "^\\d+$": {
              "format": "float",
              "type": "number"
            }
          },
          "type": [
            "object",
            "null"
          ]
        },
        "logprobs": {
          "description": "Whether to return log-probabilities.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "max_tokens": {
          "description": "Maximum completion tokens.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "messages": {
          "description": "Chat messages (system/user/assistant/tool).",
          "items": {
            "$ref": "#/$defs/ChatMessage"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "min_p": {
          "description": "Min-p sampling cutoff.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "mirostat": {
          "anyOf": [
            {
              "$ref": "#/$defs/Mirostat"
            },
            {
              "type": "null"
            }
          ],
          "description": "Mirostat sampling."
        },
        "model_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelConfig"
            },
            {
              "type": "null"
            }
          ],
          "description": "Per-model load/context configuration."
        },
        "presence_penalty": {
          "description": "Presence penalty.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "prompt": {
          "description": "Raw completion prompt (base models / full control).",
          "type": [
            "string",
            "null"
          ]
        },
        "repeat_last_n": {
          "description": "Repetition penalty look-back window.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "repeat_penalty": {
          "description": "Repetition penalty.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "response_format": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResponseFormat"
            },
            {
              "type": "null"
            }
          ],
          "description": "Output format constraint."
        },
        "seed": {
          "description": "Deterministic sampling seed.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "stop": {
          "description": "Stop sequences.",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "stop_token_ids": {
          "description": "Token-id stop sequences (local).",
          "items": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "temperature": {
          "description": "Sampling temperature.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "tfs_z": {
          "description": "Tail-free sampling z.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "tool_choice": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolChoice"
            },
            {
              "type": "null"
            }
          ],
          "description": "How the model should choose among `tools`."
        },
        "tools": {
          "description": "Tools (functions) the model may call.",
          "items": {
            "$ref": "#/$defs/Tool"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "top_k": {
          "description": "Top-k sampling cutoff.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "top_logprobs": {
          "description": "Number of top log-probabilities to return per token.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "top_p": {
          "description": "Nucleus sampling cutoff.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "typical_p": {
          "description": "Typical-p (locally typical) sampling.",
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ChatResponse": {
      "description": "A generation response (OpenAI-shaped, minimal).",
      "properties": {
        "choices": {
          "description": "Generation choices (one today).",
          "items": {
            "$ref": "#/$defs/ChatChoice"
          },
          "type": "array"
        },
        "model": {
          "description": "Resolved model spec.",
          "type": "string"
        },
        "usage": {
          "$ref": "#/$defs/Usage",
          "description": "Token usage."
        }
      },
      "required": [
        "model",
        "choices",
        "usage"
      ],
      "type": "object"
    },
    "FinishReason": {
      "description": "Why generation stopped (OpenAI `finish_reason` + Strata `cancelled`).",
      "oneOf": [
        {
          "const": "stop",
          "description": "Hit a stop token or stop sequence.",
          "type": "string"
        },
        {
          "const": "length",
          "description": "Hit the max-token or context limit.",
          "type": "string"
        },
        {
          "const": "tool_calls",
          "description": "Stopped to call tools (phase 2).",
          "type": "string"
        },
        {
          "const": "content_filter",
          "description": "Stopped by a content filter.",
          "type": "string"
        },
        {
          "const": "cancelled",
          "description": "Cancelled by provider policy or caller control.",
          "type": "string"
        }
      ]
    },
    "FunctionDef": {
      "description": "A function tool definition.",
      "properties": {
        "description": {
          "description": "What the function does (helps the model decide when to call it).",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Function name the model calls.",
          "type": "string"
        },
        "parameters": {
          "description": "JSON Schema describing the arguments object."
        },
        "strict": {
          "description": "Enforce strict schema adherence. Provider-dependent.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "JsonSchemaSpec": {
      "description": "A named JSON Schema for structured outputs (OpenAI `json_schema` block).",
      "properties": {
        "description": {
          "description": "Human-readable description of the schema's intent.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Schema name (the identifier the model is told to conform to).",
          "type": "string"
        },
        "schema": {
          "description": "The JSON Schema the output must validate against."
        },
        "strict": {
          "description": "Enforce strict adherence (no additional properties). Provider-dependent;\nenforced exactly for local (GBNF) and OpenAI structured outputs.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "schema"
      ],
      "type": "object"
    },
    "LogProbs": {
      "description": "Per-token log-probabilities for a choice (OpenAI `logprobs.content`).",
      "properties": {
        "content": {
          "description": "One entry per generated token, in order.",
          "items": {
            "$ref": "#/$defs/TokenLogProb"
          },
          "type": "array"
        }
      },
      "required": [
        "content"
      ],
      "type": "object"
    },
    "Mirostat": {
      "description": "Mirostat perplexity-control sampling (llama.cpp extension).",
      "properties": {
        "eta": {
          "description": "Learning rate (eta).",
          "format": "float",
          "type": "number"
        },
        "mode": {
          "description": "Algorithm version: 1 or 2.",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "tau": {
          "description": "Target entropy (tau).",
          "format": "float",
          "type": "number"
        }
      },
      "required": [
        "mode",
        "tau",
        "eta"
      ],
      "type": "object"
    },
    "ModelConfig": {
      "description": "Per-model load/context configuration (llama.cpp local; ignored by cloud).\nSet once and cache-keyed — not repeated per call.",
      "properties": {
        "chat_format": {
          "description": "Named chat template (e.g. `\"chatml\"`, `\"llama3\"`, `\"gemma\"`) overriding\nthe model's embedded `tokenizer.chat_template`.",
          "type": [
            "string",
            "null"
          ]
        },
        "flash_attn": {
          "description": "Enable flash attention.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "n_batch": {
          "description": "Logical batch size.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "n_ctx": {
          "description": "Context window size.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "n_gpu_layers": {
          "description": "GPU layers to offload (-1 = all).",
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "n_threads": {
          "description": "CPU threads.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "pooling": {
          "anyOf": [
            {
              "$ref": "#/$defs/Pooling"
            },
            {
              "type": "null"
            }
          ],
          "description": "Embedding pooling strategy."
        }
      },
      "type": "object"
    },
    "NamedToolChoice": {
      "description": "Force a specific function call (`{\"type\":\"function\",\"function\":{\"name\":…}}`).",
      "oneOf": [
        {
          "description": "Require the named function.",
          "properties": {
            "function": {
              "$ref": "#/$defs/ToolChoiceFunction",
              "description": "The function to force."
            },
            "type": {
              "const": "function",
              "type": "string"
            }
          },
          "required": [
            "type",
            "function"
          ],
          "type": "object"
        }
      ]
    },
    "Pooling": {
      "description": "Embedding pooling strategy (a context-creation param — load-time).",
      "oneOf": [
        {
          "const": "mean",
          "description": "Mean over tokens.",
          "type": "string"
        },
        {
          "const": "cls",
          "description": "CLS token.",
          "type": "string"
        },
        {
          "const": "last",
          "description": "Last token.",
          "type": "string"
        },
        {
          "const": "rank",
          "description": "Reranker pooling.",
          "type": "string"
        }
      ]
    },
    "ResponseFormat": {
      "description": "Output format constraint.\n\n`JsonSchema` carries the schema as an opaque [`serde_json::Value`], so this\nenum is [`PartialEq`] but not [`Eq`].",
      "oneOf": [
        {
          "description": "Free-form text (default).",
          "properties": {
            "type": {
              "const": "text",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Constrain output to a single JSON object.",
          "properties": {
            "type": {
              "const": "json_object",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Constrain output to a caller-supplied JSON Schema (structured outputs).",
          "properties": {
            "json_schema": {
              "$ref": "#/$defs/JsonSchemaSpec",
              "description": "The named schema the output must conform to."
            },
            "type": {
              "const": "json_schema",
              "type": "string"
            }
          },
          "required": [
            "type",
            "json_schema"
          ],
          "type": "object"
        }
      ]
    },
    "Role": {
      "description": "A chat message role.",
      "oneOf": [
        {
          "const": "system",
          "description": "System / developer instructions.",
          "type": "string"
        },
        {
          "const": "user",
          "description": "End-user turn.",
          "type": "string"
        },
        {
          "const": "assistant",
          "description": "Model turn (also used for assistant prefill).",
          "type": "string"
        },
        {
          "const": "tool",
          "description": "Tool result turn (function calling — phase 2).",
          "type": "string"
        }
      ]
    },
    "TokenLogProb": {
      "description": "Log-probability of one generated token.",
      "properties": {
        "bytes": {
          "description": "Raw UTF-8 bytes of the token (present when it is not standalone-UTF-8).",
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "logprob": {
          "description": "Natural-log probability of the token.",
          "format": "float",
          "type": "number"
        },
        "token": {
          "description": "The token text.",
          "type": "string"
        },
        "top_logprobs": {
          "description": "The most likely alternatives at this position (up to `top_logprobs`).",
          "items": {
            "$ref": "#/$defs/TopLogProb"
          },
          "type": "array"
        }
      },
      "required": [
        "token",
        "logprob"
      ],
      "type": "object"
    },
    "Tool": {
      "description": "A tool the model may call. Only `function` tools exist today (OpenAI-shaped);\nthe tagged form reserves room for future tool kinds.\n\nHolds a JSON-Schema [`serde_json::Value`], so this type is [`PartialEq`] but\nnot [`Eq`].",
      "oneOf": [
        {
          "description": "A function tool with a JSON-Schema parameter contract.",
          "properties": {
            "function": {
              "$ref": "#/$defs/FunctionDef",
              "description": "The function definition."
            },
            "type": {
              "const": "function",
              "type": "string"
            }
          },
          "required": [
            "type",
            "function"
          ],
          "type": "object"
        }
      ]
    },
    "ToolCall": {
      "description": "A tool call emitted by the assistant.",
      "oneOf": [
        {
          "description": "A function invocation.",
          "properties": {
            "function": {
              "$ref": "#/$defs/ToolCallFunction",
              "description": "The invoked function and its arguments."
            },
            "id": {
              "description": "Provider-assigned call id (echoed in the answering `tool` message).",
              "type": "string"
            },
            "type": {
              "const": "function",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "function"
          ],
          "type": "object"
        }
      ]
    },
    "ToolCallFunction": {
      "description": "The function invoked by a [`ToolCall`].",
      "properties": {
        "arguments": {
          "description": "Arguments as a JSON-encoded string (OpenAI convention).",
          "type": "string"
        },
        "name": {
          "description": "Function name.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "arguments"
      ],
      "type": "object"
    },
    "ToolChoice": {
      "anyOf": [
        {
          "$ref": "#/$defs/ToolChoiceMode",
          "description": "A coarse mode: `none`, `auto`, or `required`."
        },
        {
          "$ref": "#/$defs/NamedToolChoice",
          "description": "Force a specific named function."
        }
      ],
      "description": "How the model should choose among the offered `tools`."
    },
    "ToolChoiceFunction": {
      "description": "The function a [`NamedToolChoice`] forces.",
      "properties": {
        "name": {
          "description": "Function name to force.",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ToolChoiceMode": {
      "description": "Coarse tool-choice mode.",
      "oneOf": [
        {
          "const": "none",
          "description": "Never call a tool.",
          "type": "string"
        },
        {
          "const": "auto",
          "description": "Model decides whether to call a tool.",
          "type": "string"
        },
        {
          "const": "required",
          "description": "Model must call at least one tool.",
          "type": "string"
        }
      ]
    },
    "TopLogProb": {
      "description": "One alternative token and its log-probability.",
      "properties": {
        "bytes": {
          "description": "Raw UTF-8 bytes of the token.",
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "logprob": {
          "description": "Natural-log probability of the token.",
          "format": "float",
          "type": "number"
        },
        "token": {
          "description": "The token text.",
          "type": "string"
        }
      },
      "required": [
        "token",
        "logprob"
      ],
      "type": "object"
    },
    "Usage": {
      "description": "Token usage accounting.",
      "properties": {
        "completion_tokens": {
          "description": "Completion token count.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "prompt_tokens": {
          "description": "Prompt token count.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "total_tokens": {
          "description": "Total tokens.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "prompt_tokens",
        "completion_tokens",
        "total_tokens"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/inference.generate.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "inference.generate",
  "request": {
    "additionalProperties": false,
    "description": "Generates text with an inference model.",
    "properties": {
      "model": {
        "description": "Model spec.",
        "type": "string"
      },
      "request": {
        "$ref": "#/$defs/ChatRequest",
        "description": "Generation request."
      },
      "type": {
        "const": "inference_generate",
        "type": "string"
      }
    },
    "required": [
      "type",
      "model",
      "request"
    ],
    "type": "object"
  },
  "response": {
    "description": "Inference generation output.",
    "properties": {
      "data": {
        "$ref": "#/$defs/ChatResponse"
      },
      "type": {
        "const": "inference_generation",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
