      "properties": {
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "first_invalid": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "length": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "valid": {
          "type": "boolean"
        }
      },
      "required": [
        "valid",
        "length"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/event.verify_chain.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "event.verify_chain",
  "request": {
    "additionalProperties": false,
    "description": "Verifies visible event density and hash linkage.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "event_verify_chain",
        "type": "string"
      }
    },
    "required": [
      "type"
    ],
    "type": "object"
  },
  "response": {
    "description": "Event hash-chain verification result.",
    "properties": {
      "data": {
        "$ref": "#/$defs/EventChainVerification"
      },
      "type": {
        "const": "event_chain_verification",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
