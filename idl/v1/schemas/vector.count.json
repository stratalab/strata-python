{
  "$id": "https://stratadb.org/idl/v1/schemas/vector.count.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "vector.count",
  "request": {
    "additionalProperties": false,
    "description": "Counts visible vectors in one collection.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "collection": {
        "description": "Collection name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "vector_count",
        "type": "string"
      }
    },
    "required": [
      "type",
      "collection"
    ],
    "type": "object"
  },
  "response": {
    "description": "Unsigned integer result.",
    "properties": {
      "data": {
        "format": "uint64",
        "minimum": 0,
        "type": "integer"
      },
      "type": {
        "const": "uint",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
