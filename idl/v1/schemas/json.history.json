{
  "$defs": {
    "JsonHistoryItem": {
      "description": "JSON version-history item.",
      "properties": {
        "document_version": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "tombstone": {
          "type": "boolean"
        },
        "value": true,
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "tombstone"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/json.history.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "json.history",
  "request": {
    "additionalProperties": false,
    "description": "Reads full JSON document version history.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "key": {
        "description": "Document key.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "json_history",
        "type": "string"
      }
    },
    "required": [
      "type",
      "key"
    ],
    "type": "object"
  },
  "response": {
    "description": "Full JSON document version history.",
    "properties": {
      "data": {
        "items": {
          "$ref": "#/$defs/JsonHistoryItem"
        },
        "type": [
          "array",
          "null"
        ]
      },
      "type": {
        "const": "json_version_history",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
