{
  "$defs": {
    "VectorFilterCondition": {
      "description": "One vector metadata filter condition.",
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "$ref": "#/$defs/VectorFilterOp"
        },
        "value": {
          "$ref": "#/$defs/VectorScalar"
        }
      },
      "required": [
        "field",
        "op",
        "value"
      ],
      "type": "object"
    },
    "VectorFilterOp": {
      "description": "Vector metadata filter operation.",
      "oneOf": [
        {
          "const": "eq",
          "description": "Top-level equality.",
          "type": "string"
        }
      ]
    },
    "VectorIndexArtifactSource": {
      "description": "One vector index artifact diagnostic.",
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "searched": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "status",
        "searched"
      ],
      "type": "object"
    },
    "VectorIndexDiagnostics": {
      "description": "Vector index planner diagnostics.",
      "properties": {
        "active_delta_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "active_delta_seal_threshold": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "active_delta_source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "artifact_sources": {
          "items": {
            "$ref": "#/$defs/VectorIndexArtifactSource"
          },
          "type": "array"
        },
        "collection": {
          "type": "string"
        },
        "collection_exact_threshold": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "derived_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "exact_fallback_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "exact_source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "filtered_underfill_fallback": {
          "type": "boolean"
        },
        "flat_source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "hnsw_graph_builds": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "hnsw_memory_budget_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "hnsw_source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "indexed_source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "indexed_vector_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "last_query_fallback_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_query_used_index": {
          "type": "boolean"
        },
        "manifest_generation": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "manifest_inherited_ref_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "manifest_owned_ref_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "manifest_ref_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "manifest_status": {
          "type": "string"
        },
        "overfetch_factor": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "policy_mode": {
          "type": "string"
        },
        "resolved_index_kind_summary": {
          "type": "string"
        },
        "source_candidate_limit": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_flat_threshold": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_hnsw_threshold": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "collection",
        "manifest_status",
        "manifest_ref_count",
        "manifest_inherited_ref_count",
        "manifest_owned_ref_count",
        "active_delta_count",
        "policy_mode",
        "collection_exact_threshold",
        "source_flat_threshold",
        "source_hnsw_threshold",
        "overfetch_factor",
        "filtered_underfill_fallback",
        "active_delta_seal_threshold",
        "hnsw_memory_budget_bytes",
        "source_candidate_limit",
        "resolved_index_kind_summary",
        "exact_fallback_count",
        "hnsw_graph_builds",
        "indexed_source_count",
        "exact_source_count",
        "flat_source_count",
        "hnsw_source_count",
        "active_delta_source_count",
        "indexed_vector_count",
        "derived_bytes",
        "last_query_used_index",
        "artifact_sources"
      ],
      "type": "object"
    },
    "VectorIndexQueryResult": {
      "description": "Vector index search output.",
      "properties": {
        "diagnostics": {
          "$ref": "#/$defs/VectorIndexDiagnostics"
        },
        "matches": {
          "items": {
            "$ref": "#/$defs/VectorMatch"
          },
          "type": "array"
        }
      },
      "required": [
        "matches",
        "diagnostics"
      ],
      "type": "object"
    },
    "VectorMatch": {
      "description": "One vector search match.",
      "properties": {
        "key": {
          "type": "string"
        },
        "metadata": true,
        "score": {
          "format": "float",
          "type": "number"
        }
      },
      "required": [
        "key",
        "score"
      ],
      "type": "object"
    },
    "VectorMetadataFilter": {
      "description": "AND-composed vector metadata filter.",
      "properties": {
        "conditions": {
          "items": {
            "$ref": "#/$defs/VectorFilterCondition"
          },
          "type": "array"
        }
      },
      "required": [
        "conditions"
      ],
      "type": "object"
    },
    "VectorScalar": {
      "description": "Scalar value used by vector metadata filters.",
      "oneOf": [
        {
          "description": "JSON null.",
          "properties": {
            "type": {
              "const": "null",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Boolean scalar.",
          "properties": {
            "type": {
              "const": "bool",
              "type": "string"
            },
            "value": {
              "type": "boolean"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        },
        {
          "description": "Numeric scalar.",
          "properties": {
            "type": {
              "const": "number",
              "type": "string"
            },
            "value": {
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        },
        {
          "description": "String scalar.",
          "properties": {
            "type": {
              "const": "string",
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/vector.index.query.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "vector.index.query",
  "request": {
    "additionalProperties": false,
    "description": "Runs vector search and returns index planner diagnostics.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "collection": {
        "description": "Collection name.",
        "type": "string"
      },
      "filter": {
        "anyOf": [
          {
            "$ref": "#/$defs/VectorMetadataFilter"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional metadata filter."
      },
      "k": {
        "description": "Maximum number of matches.",
        "format": "uint64",
        "minimum": 0,
        "type": "integer"
      },
      "query": {
        "description": "Query embedding. Accepted at wire (f64) precision and narrowed to the\nsearched f32; a value that underflows or overflows f32 is rejected.",
        "items": {
          "format": "double",
          "type": "number"
        },
        "type": "array"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "vector_index_query",
        "type": "string"
      }
    },
    "required": [
      "type",
      "collection",
      "query",
      "k"
    ],
    "type": "object"
  },
  "response": {
    "description": "Vector search matches plus index planner diagnostics.",
    "properties": {
      "data": {
        "$ref": "#/$defs/VectorIndexQueryResult"
      },
      "type": {
        "const": "vector_index_query",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
