{
  "$defs": {
    "GraphAnalyticsBudget": {
      "description": "Optional size bounds for one graph analytics snapshot (input form).\nUnset fields use the engine defaults.",
      "properties": {
        "max_edges": {
          "description": "Maximum edge count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_nodes": {
          "description": "Maximum node count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "GraphCdlpData": {
      "description": "Community-detection result (wire form). Every node maps to its\ncommunity representative node id.",
      "properties": {
        "graph": {
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "graph",
        "labels"
      ],
      "type": "object"
    },
    "GraphDirection": {
      "description": "Graph neighbor traversal direction.",
      "oneOf": [
        {
          "const": "outgoing",
          "description": "Outgoing edges from the selected node.",
          "type": "string"
        },
        {
          "const": "incoming",
          "description": "Incoming edges into the selected node.",
          "type": "string"
        },
        {
          "const": "both",
          "description": "Incoming and outgoing edges.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.analytics.cdlp.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.analytics.cdlp",
  "request": {
    "additionalProperties": false,
    "description": "Detects communities via label propagation.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "budget": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphAnalyticsBudget"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional snapshot size bounds. Defaults to the engine limits."
      },
      "direction": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphDirection"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional propagation direction. Defaults to both."
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "max_iterations": {
        "description": "Optional iteration bound. Defaults to 10.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_cdlp",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Community labels computed over a graph snapshot.",
    "properties": {
      "data": {
        "$ref": "#/$defs/GraphCdlpData"
      },
      "type": {
        "const": "graph_cdlp_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
