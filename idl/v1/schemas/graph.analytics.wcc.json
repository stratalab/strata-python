{
  "$defs": {
    "GraphAnalyticsBudget": {
      "additionalProperties": false,
      "description": "Optional size bounds for one graph analytics snapshot (input form).\nUnset fields use the engine defaults.",
      "properties": {
        "max_edges": {
          "description": "Maximum edge count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_nodes": {
          "description": "Maximum node count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "GraphWccData": {
      "description": "Weakly-connected-components result (wire form). Every node maps to\nits component representative: the smallest node id in the component.",
      "properties": {
        "component_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "components": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "graph": {
          "type": "string"
        }
      },
      "required": [
        "graph",
        "components",
        "component_count"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.analytics.wcc.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.analytics.wcc",
  "request": {
    "additionalProperties": false,
    "description": "Computes weakly connected components over a graph snapshot.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "budget": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphAnalyticsBudget"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional snapshot size bounds. Defaults to the engine limits."
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_wcc",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Weakly connected components computed over a graph snapshot.",
    "properties": {
      "data": {
        "$ref": "#/$defs/GraphWccData"
      },
      "type": {
        "const": "graph_wcc_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
