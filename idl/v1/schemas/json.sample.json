{
  "$defs": {
    "JsonSampleItem": {
      "description": "Sampled JSON document.",
      "properties": {
        "document_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "key": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "value": true,
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "key",
        "value",
        "version",
        "timestamp",
        "document_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/json.sample.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "json.sample",
  "request": {
    "additionalProperties": false,
    "description": "Samples JSON documents.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "count": {
        "description": "Optional sample count. Defaults to 10.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "description": "Optional document key prefix.",
        "type": [
          "string",
          "null"
        ]
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "json_sample",
        "type": "string"
      }
    },
    "required": [
      "type"
    ],
    "type": "object"
  },
  "response": {
    "description": "Sampled JSON documents.",
    "properties": {
      "data": {
        "description": "Shared pagination continuation facts.",
        "properties": {
          "cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "has_more": {
            "type": "boolean"
          },
          "items": {
            "description": "Sampled documents.",
            "items": {
              "$ref": "#/$defs/JsonSampleItem"
            },
            "type": "array"
          },
          "total_count": {
            "description": "Total matching live documents.",
            "format": "uint64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "total_count",
          "items",
          "has_more"
        ],
        "type": "object"
      },
      "type": {
        "const": "json_sample_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
