{
  "$defs": {
    "GraphAnalyticsBudget": {
      "additionalProperties": false,
      "description": "Optional size bounds for one graph analytics snapshot (input form).\nUnset fields use the engine defaults.",
      "properties": {
        "max_edges": {
          "description": "Maximum edge count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_nodes": {
          "description": "Maximum node count admitted into the snapshot.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "GraphDirection": {
      "description": "Graph neighbor traversal direction.",
      "oneOf": [
        {
          "const": "outgoing",
          "description": "Outgoing edges from the selected node.",
          "type": "string"
        },
        {
          "const": "incoming",
          "description": "Incoming edges into the selected node.",
          "type": "string"
        },
        {
          "const": "both",
          "description": "Incoming and outgoing edges.",
          "type": "string"
        }
      ]
    },
    "GraphSsspData": {
      "description": "Shortest-path result (wire form). Unreachable nodes are omitted.",
      "properties": {
        "direction": {
          "$ref": "#/$defs/GraphDirection"
        },
        "distances": {
          "additionalProperties": {
            "format": "double",
            "type": "number"
          },
          "type": "object"
        },
        "graph": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "graph",
        "source",
        "direction",
        "distances"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.analytics.sssp.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.analytics.sssp",
  "request": {
    "additionalProperties": false,
    "description": "Computes shortest-path distances from a source node.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "budget": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphAnalyticsBudget"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional snapshot size bounds. Defaults to the engine limits."
      },
      "direction": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphDirection"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional traversal direction. Defaults to outgoing."
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "source": {
        "description": "Source node id.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_sssp",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph",
      "source"
    ],
    "type": "object"
  },
  "response": {
    "description": "Shortest-path distances computed over a graph snapshot.",
    "properties": {
      "data": {
        "$ref": "#/$defs/GraphSsspData"
      },
      "type": {
        "const": "graph_sssp_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
