{
  "$defs": {
    "Maybe2": {
      "description": "Point-read envelope shared by every capability's single-record `get`.\n\n`found` is the authoritative presence flag; `value` carries the record only\nwhen it exists. A missing record serializes as `{found: false, value: null}`\nand a present one as `{found: true, value: <record>}`, so absence never\naliases a bare `null` payload and every primitive answers a point read the\nsame shape.\n\nThe payload is `Option<T>` because these primitives never store a JSON\n`null` as a record — struct payloads round-trip cleanly through\n`Option<T>`. JSON is the one exception: a stored JSON `null` is a real value\nthat `Option<serde_json::Value>` would collapse to absence on deserialize,\nso JSON reads use the dedicated [`MaybeJsonValue`](super::MaybeJsonValue)\nenvelope, which carries a non-optional `value` to keep found-null distinct\nfrom absent. Both envelopes serialize the same `{found, value}` wire shape.",
      "properties": {
        "found": {
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/VectorVersionedData"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "found"
      ],
      "type": "object"
    },
    "VectorData": {
      "description": "Vector value payload.",
      "properties": {
        "embedding": {
          "items": {
            "format": "float",
            "type": "number"
          },
          "type": "array"
        },
        "metadata": true
      },
      "required": [
        "embedding"
      ],
      "type": "object"
    },
    "VectorVersionedData": {
      "description": "Vector value with commit metadata.",
      "properties": {
        "data": {
          "$ref": "#/$defs/VectorData"
        },
        "key": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "vector_revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "key",
        "data",
        "version",
        "timestamp",
        "vector_revision"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/vector.get.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "vector.get",
  "request": {
    "additionalProperties": false,
    "description": "Reads one vector.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "collection": {
        "description": "Collection name.",
        "type": "string"
      },
      "key": {
        "description": "Vector key.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "vector_get",
        "type": "string"
      }
    },
    "required": [
      "type",
      "collection",
      "key"
    ],
    "type": "object"
  },
  "response": {
    "description": "Vector point-read result: present value with commit metadata, or absence.",
    "properties": {
      "data": {
        "$ref": "#/$defs/Maybe2"
      },
      "type": {
        "const": "vector_data",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
