{
  "$defs": {
    "CommitReceipt": {
      "description": "Commit facts returned by mutating operations.",
      "properties": {
        "delete_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "durable": {
          "type": "boolean"
        },
        "put_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "durable",
        "put_count",
        "delete_count"
      ],
      "type": "object"
    },
    "MutationEffect": {
      "description": "Normalized mutation effect facts.",
      "properties": {
        "affected_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/MutationEffectKind"
        },
        "matched": {
          "type": "boolean"
        }
      },
      "required": [
        "applied",
        "kind",
        "matched",
        "affected_count"
      ],
      "type": "object"
    },
    "MutationEffectKind": {
      "description": "High-level mutation effect for idempotent and conditional operations.",
      "oneOf": [
        {
          "const": "created",
          "description": "A new logical entity was created.",
          "type": "string"
        },
        {
          "const": "updated",
          "description": "An existing logical entity was updated.",
          "type": "string"
        },
        {
          "const": "deleted",
          "description": "An existing logical entity was deleted.",
          "type": "string"
        },
        {
          "const": "unchanged",
          "description": "The operation matched but left state unchanged.",
          "type": "string"
        },
        {
          "const": "not_found",
          "description": "The operation did not match a visible entity.",
          "type": "string"
        }
      ]
    },
    "VectorFilterCondition": {
      "description": "One vector metadata filter condition.",
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "$ref": "#/$defs/VectorFilterOp"
        },
        "value": {
          "$ref": "#/$defs/VectorScalar"
        }
      },
      "required": [
        "field",
        "op",
        "value"
      ],
      "type": "object"
    },
    "VectorFilterOp": {
      "description": "Vector metadata filter operation.",
      "oneOf": [
        {
          "const": "eq",
          "description": "Top-level equality.",
          "type": "string"
        }
      ]
    },
    "VectorMetadataFilter": {
      "description": "AND-composed vector metadata filter.",
      "properties": {
        "conditions": {
          "items": {
            "$ref": "#/$defs/VectorFilterCondition"
          },
          "type": "array"
        }
      },
      "required": [
        "conditions"
      ],
      "type": "object"
    },
    "VectorScalar": {
      "description": "Scalar value used by vector metadata filters.",
      "oneOf": [
        {
          "description": "JSON null.",
          "properties": {
            "type": {
              "const": "null",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Boolean scalar.",
          "properties": {
            "type": {
              "const": "bool",
              "type": "string"
            },
            "value": {
              "type": "boolean"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        },
        {
          "description": "Numeric scalar.",
          "properties": {
            "type": {
              "const": "number",
              "type": "string"
            },
            "value": {
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        },
        {
          "description": "String scalar.",
          "properties": {
            "type": {
              "const": "string",
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/vector.delete_by_filter.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "vector.delete_by_filter",
  "request": {
    "additionalProperties": false,
    "description": "Deletes vectors matching a metadata filter.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "collection": {
        "description": "Collection name.",
        "type": "string"
      },
      "filter": {
        "$ref": "#/$defs/VectorMetadataFilter",
        "description": "Metadata filter."
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "vector_delete_by_filter",
        "type": "string"
      }
    },
    "required": [
      "type",
      "collection",
      "filter"
    ],
    "type": "object"
  },
  "response": {
    "description": "Vector bulk delete acknowledgement.",
    "properties": {
      "data": {
        "properties": {
          "collection": {
            "description": "Collection name.",
            "type": "string"
          },
          "commit": {
            "anyOf": [
              {
                "$ref": "#/$defs/CommitReceipt"
              },
              {
                "type": "null"
              }
            ],
            "description": "Commit receipt when deletes were applied."
          },
          "effect": {
            "$ref": "#/$defs/MutationEffect",
            "description": "Mutation effect facts."
          }
        },
        "required": [
          "collection",
          "effect"
        ],
        "type": "object"
      },
      "type": {
        "const": "vector_bulk_delete_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
