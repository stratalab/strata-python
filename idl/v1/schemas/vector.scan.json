{
  "$defs": {
    "VectorData": {
      "description": "Vector value payload.",
      "properties": {
        "embedding": {
          "items": {
            "format": "float",
            "type": "number"
          },
          "type": "array"
        },
        "metadata": true
      },
      "required": [
        "embedding"
      ],
      "type": "object"
    },
    "VectorVersionedData": {
      "description": "Vector value with commit metadata.",
      "properties": {
        "data": {
          "$ref": "#/$defs/VectorData"
        },
        "key": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "vector_revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "key",
        "data",
        "version",
        "timestamp",
        "vector_revision"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/vector.scan.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "vector.scan",
  "request": {
    "additionalProperties": false,
    "description": "Scans vectors.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "collection": {
        "description": "Collection name.",
        "type": "string"
      },
      "limit": {
        "description": "Optional row limit.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "start": {
        "description": "Optional inclusive start key.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "vector_scan",
        "type": "string"
      }
    },
    "required": [
      "type",
      "collection"
    ],
    "type": "object"
  },
  "response": {
    "description": "Vector scan page.",
    "properties": {
      "data": {
        "description": "Shared pagination continuation facts.",
        "properties": {
          "cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "has_more": {
            "type": "boolean"
          },
          "items": {
            "description": "Vectors in this page.",
            "items": {
              "$ref": "#/$defs/VectorVersionedData"
            },
            "type": "array"
          }
        },
        "required": [
          "items",
          "has_more"
        ],
        "type": "object"
      },
      "type": {
        "const": "vector_scan_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
