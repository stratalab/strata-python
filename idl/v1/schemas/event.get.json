{
  "$defs": {
    "EventData": {
      "description": "Event record payload and chain facts.",
      "properties": {
        "event_type": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        },
        "payload": true,
        "previous_hash": {
          "type": "string"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "sequence",
        "event_type",
        "payload",
        "timestamp",
        "previous_hash",
        "hash"
      ],
      "type": "object"
    },
    "EventVersionedData": {
      "description": "Event record with commit metadata.",
      "properties": {
        "event": {
          "$ref": "#/$defs/EventData"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "event",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "Maybe3": {
      "description": "Point-read envelope shared by every capability's single-record `get`.\n\n`found` is the authoritative presence flag; `value` carries the record only\nwhen it exists. A missing record serializes as `{found: false, value: null}`\nand a present one as `{found: true, value: <record>}`, so absence never\naliases a bare `null` payload and every primitive answers a point read the\nsame shape.\n\nThe payload is `Option<T>` because these primitives never store a JSON\n`null` as a record — struct payloads round-trip cleanly through\n`Option<T>`. JSON is the one exception: a stored JSON `null` is a real value\nthat `Option<serde_json::Value>` would collapse to absence on deserialize,\nso JSON reads use the dedicated [`MaybeJsonValue`](super::MaybeJsonValue)\nenvelope, which carries a non-optional `value` to keep found-null distinct\nfrom absent. Both envelopes serialize the same `{found, value}` wire shape.",
      "properties": {
        "found": {
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventVersionedData"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "found"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/event.get.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "event.get",
  "request": {
    "additionalProperties": false,
    "description": "Reads one event by sequence.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "sequence": {
        "description": "Event sequence.",
        "format": "uint64",
        "minimum": 0,
        "type": "integer"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "event_get",
        "type": "string"
      }
    },
    "required": [
      "type",
      "sequence"
    ],
    "type": "object"
  },
  "response": {
    "description": "Event point-read result: present record with commit metadata, or absence.",
    "properties": {
      "data": {
        "$ref": "#/$defs/Maybe3"
      },
      "type": {
        "const": "event_record",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
