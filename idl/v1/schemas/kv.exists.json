{
  "$defs": {
    "Bytes": {
      "contentEncoding": "base64",
      "description": "Binary payload encoded as a standard base64 string.",
      "type": "string"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/kv.exists.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "kv.exists",
  "request": {
    "additionalProperties": false,
    "description": "Checks one key for existence.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "key": {
        "$ref": "#/$defs/Bytes",
        "description": "Key to check."
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "kv_exists",
        "type": "string"
      }
    },
    "required": [
      "type",
      "key"
    ],
    "type": "object"
  },
  "response": {
    "description": "Boolean result.",
    "properties": {
      "data": {
        "type": "boolean"
      },
      "type": {
        "const": "bool",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
