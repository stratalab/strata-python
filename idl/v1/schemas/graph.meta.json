{
  "$defs": {
    "GraphInfoData": {
      "description": "Serializable graph metadata.",
      "properties": {
        "created_timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "created_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "edge_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "graph": {
          "type": "string"
        },
        "node_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "updated_timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "updated_version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "node_count",
        "edge_count",
        "created_version",
        "created_timestamp",
        "updated_version",
        "updated_timestamp"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.meta.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.meta",
  "request": {
    "additionalProperties": false,
    "description": "Reads graph metadata.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_get_meta",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph"
    ],
    "type": "object"
  },
  "response": {
    "description": "Optional graph metadata.",
    "properties": {
      "data": {
        "anyOf": [
          {
            "$ref": "#/$defs/GraphInfoData"
          },
          {
            "type": "null"
          }
        ]
      },
      "type": {
        "const": "graph_info_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
