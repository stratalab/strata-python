{
  "$defs": {
    "CommitReceipt": {
      "description": "Commit facts returned by mutating operations.",
      "properties": {
        "delete_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "durable": {
          "type": "boolean"
        },
        "put_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "version",
        "timestamp",
        "durable",
        "put_count",
        "delete_count"
      ],
      "type": "object"
    },
    "MutationEffect": {
      "description": "Normalized mutation effect facts.",
      "properties": {
        "affected_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/MutationEffectKind"
        },
        "matched": {
          "type": "boolean"
        }
      },
      "required": [
        "applied",
        "kind",
        "matched",
        "affected_count"
      ],
      "type": "object"
    },
    "MutationEffectKind": {
      "description": "High-level mutation effect for idempotent and conditional operations.",
      "oneOf": [
        {
          "const": "created",
          "description": "A new logical entity was created.",
          "type": "string"
        },
        {
          "const": "updated",
          "description": "An existing logical entity was updated.",
          "type": "string"
        },
        {
          "const": "deleted",
          "description": "An existing logical entity was deleted.",
          "type": "string"
        },
        {
          "const": "unchanged",
          "description": "The operation matched but left state unchanged.",
          "type": "string"
        },
        {
          "const": "not_found",
          "description": "The operation did not match a visible entity.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/space.create.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "space.create",
  "request": {
    "additionalProperties": false,
    "description": "Creates a product space for a branch.\n\n# Guaranteed semantics\n\n- **Idempotent success.** Creating a space that already exists is not\n  an error: the command succeeds with `created: false` and no mutation\n  effect. `created: true` is reported only by the call that first\n  materialized the space.\n- **Immediate visibility.** Once the command returns success, the\n  space is visible to every subsequent command on any handle of the\n  same database — `SpaceExists` reports `true` and data commands\n  targeting the space are accepted.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "space": {
        "description": "Product space name.",
        "type": "string"
      },
      "type": {
        "const": "space_create",
        "type": "string"
      }
    },
    "required": [
      "type",
      "space"
    ],
    "type": "object"
  },
  "response": {
    "description": "Product space create result.",
    "properties": {
      "data": {
        "properties": {
          "commit": {
            "anyOf": [
              {
                "$ref": "#/$defs/CommitReceipt"
              },
              {
                "type": "null"
              }
            ],
            "description": "Commit receipt when a catalog mutation was applied."
          },
          "effect": {
            "$ref": "#/$defs/MutationEffect",
            "description": "Mutation effect facts."
          },
          "space": {
            "description": "Product space name.",
            "type": "string"
          }
        },
        "required": [
          "space",
          "effect"
        ],
        "type": "object"
      },
      "type": {
        "const": "space_create_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
