{
  "$defs": {
    "Bytes": {
      "contentEncoding": "base64",
      "description": "Binary payload encoded as a standard base64 string.",
      "type": "string"
    },
    "SampleItem": {
      "description": "Sampled KV item.",
      "properties": {
        "key": {
          "$ref": "#/$defs/Bytes"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "value": {
          "$ref": "#/$defs/Bytes"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "key",
        "value",
        "version",
        "timestamp"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/kv.sample.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "kv.sample",
  "request": {
    "additionalProperties": false,
    "description": "Samples keys and values.",
    "properties": {
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "count": {
        "description": "Optional sample count. Defaults to 10.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "prefix": {
        "anyOf": [
          {
            "$ref": "#/$defs/Bytes"
          },
          {
            "type": "null"
          }
        ],
        "description": "Optional key prefix."
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "kv_sample",
        "type": "string"
      }
    },
    "required": [
      "type"
    ],
    "type": "object"
  },
  "response": {
    "description": "Sampled KV result.",
    "properties": {
      "data": {
        "description": "Shared pagination continuation facts.",
        "properties": {
          "cursor": {
            "anyOf": [
              {
                "$ref": "#/$defs/Bytes"
              },
              {
                "type": "null"
              }
            ]
          },
          "has_more": {
            "type": "boolean"
          },
          "items": {
            "description": "Sampled rows.",
            "items": {
              "$ref": "#/$defs/SampleItem"
            },
            "type": "array"
          },
          "total_count": {
            "description": "Total matching live rows.",
            "format": "uint64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "total_count",
          "items",
          "has_more"
        ],
        "type": "object"
      },
      "type": {
        "const": "sample_result",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
