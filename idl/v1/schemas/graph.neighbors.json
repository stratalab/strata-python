{
  "$defs": {
    "GraphBindingPrimitive": {
      "description": "Product primitive kind used by graph entity bindings.",
      "oneOf": [
        {
          "const": "kv",
          "description": "KV primitive.",
          "type": "string"
        },
        {
          "const": "json",
          "description": "JSON primitive.",
          "type": "string"
        },
        {
          "const": "vector",
          "description": "Vector primitive.",
          "type": "string"
        },
        {
          "const": "event",
          "description": "Event primitive.",
          "type": "string"
        },
        {
          "const": "graph",
          "description": "Graph primitive.",
          "type": "string"
        }
      ]
    },
    "GraphBindingTarget": {
      "description": "Typed product identity attached to a graph node.",
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "type": "string"
        },
        "primitive": {
          "$ref": "#/$defs/GraphBindingPrimitive"
        },
        "space": {
          "type": "string"
        }
      },
      "required": [
        "primitive",
        "space",
        "key"
      ],
      "type": "object"
    },
    "GraphDirection": {
      "description": "Graph neighbor traversal direction.",
      "oneOf": [
        {
          "const": "outgoing",
          "description": "Outgoing edges from the selected node.",
          "type": "string"
        },
        {
          "const": "incoming",
          "description": "Incoming edges into the selected node.",
          "type": "string"
        },
        {
          "const": "both",
          "description": "Incoming and outgoing edges.",
          "type": "string"
        }
      ]
    },
    "GraphEdgeDataOutput": {
      "description": "Serializable graph edge output.",
      "properties": {
        "dst": {
          "type": "string"
        },
        "edge_type": {
          "type": "string"
        },
        "graph": {
          "type": "string"
        },
        "properties": true,
        "src": {
          "type": "string"
        },
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "weight": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "graph",
        "src",
        "edge_type",
        "dst",
        "weight",
        "version",
        "timestamp"
      ],
      "type": "object"
    },
    "GraphEntityBinding": {
      "description": "Node-to-entity binding.",
      "properties": {
        "target": {
          "$ref": "#/$defs/GraphBindingTarget"
        }
      },
      "required": [
        "target"
      ],
      "type": "object"
    },
    "GraphNeighborHit": {
      "description": "Serializable graph neighbor hit.",
      "properties": {
        "direction": {
          "$ref": "#/$defs/GraphDirection"
        },
        "dst": {
          "type": "string"
        },
        "edge": {
          "$ref": "#/$defs/GraphEdgeDataOutput"
        },
        "edge_type": {
          "type": "string"
        },
        "graph": {
          "type": "string"
        },
        "node": {
          "$ref": "#/$defs/GraphNodeDataOutput"
        },
        "node_id": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "target_status": {
          "description": "Bound-entity resolution status; absent when the node is unbound.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "graph",
        "node_id",
        "src",
        "edge_type",
        "dst",
        "direction",
        "node",
        "edge"
      ],
      "type": "object"
    },
    "GraphNodeDataOutput": {
      "description": "Serializable graph node output.",
      "properties": {
        "binding": {
          "anyOf": [
            {
              "$ref": "#/$defs/GraphEntityBinding"
            },
            {
              "type": "null"
            }
          ]
        },
        "graph": {
          "type": "string"
        },
        "node_id": {
          "type": "string"
        },
        "object_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "properties": true,
        "timestamp": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "version": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "graph",
        "node_id",
        "version",
        "timestamp"
      ],
      "type": "object"
    }
  },
  "$id": "https://stratadb.org/idl/v1/schemas/graph.neighbors.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "command": "graph.neighbors",
  "request": {
    "additionalProperties": false,
    "description": "Lists neighboring graph nodes.",
    "properties": {
      "as_of": {
        "description": "Optional timestamp in microseconds. Reads the graph state visible at that instant.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "branch": {
        "description": "Target branch. Defaults to the executor handle branch.",
        "type": [
          "string",
          "null"
        ]
      },
      "cursor": {
        "description": "Optional exclusive cursor.",
        "type": [
          "string",
          "null"
        ]
      },
      "direction": {
        "$ref": "#/$defs/GraphDirection",
        "description": "Traversal direction."
      },
      "edge_type": {
        "description": "Optional edge type filter.",
        "type": [
          "string",
          "null"
        ]
      },
      "graph": {
        "description": "Graph name.",
        "type": "string"
      },
      "limit": {
        "description": "Optional item limit. Defaults to 100.",
        "format": "uint64",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "node_id": {
        "description": "Node id.",
        "type": "string"
      },
      "space": {
        "description": "Target product space. Defaults to `\"default\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "type": {
        "const": "graph_neighbors",
        "type": "string"
      }
    },
    "required": [
      "type",
      "graph",
      "node_id",
      "direction"
    ],
    "type": "object"
  },
  "response": {
    "description": "Paginated graph neighbor list.",
    "properties": {
      "data": {
        "description": "Shared pagination continuation facts.",
        "properties": {
          "cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "has_more": {
            "type": "boolean"
          },
          "items": {
            "description": "Neighbor hits in this page.",
            "items": {
              "$ref": "#/$defs/GraphNeighborHit"
            },
            "type": "array"
          }
        },
        "required": [
          "items",
          "has_more"
        ],
        "type": "object"
      },
      "type": {
        "const": "graph_neighbor_page",
        "type": "string"
      }
    },
    "required": [
      "type",
      "data"
    ],
    "type": "object"
  }
}
